# Nginx Opcache Manager Plugin Configuration

# Cache Settings
# Path to your Nginx cache directory
# Default: /var/run/nginx-cache
NOM_NGINX_CACHE_PATH=/var/run/nginx-cache

# Enable Nginx cache monitoring
# true or false
NOM_NGINX_CACHE_ENABLED=true

# Enable admin notifications
# true or false
NOM_ENABLE_NOTIFICATIONS=true

# Statistics Collection
# How often to collect statistics (in minutes)
# Schedule: hourly (WordPress cron)
NOM_STATS_INTERVAL=60

# Data Retention
# How many statistics records to keep
# Default: 100 (approximately 24+ hours with hourly collection)
NOM_STATS_RETENTION=100

# Logging
# Enable debug logging
# true or false
NOM_DEBUG_MODE=false

# Performance
# Cache the results for this many seconds
# 0 = no caching
NOM_CACHE_TTL=300
